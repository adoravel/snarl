{
	"name": "@404/imouto",
	"description": "a minimal full-stack web framework for deno",
	"version": "0.1.3",
	"license": "Apache-2.0",
	"exports": {
		".": "./src/mod.ts",
		"./jsx-runtime": "./src/jsx-runtime.ts",
		"./jsx-dev-runtime": "./src/jsx-runtime.ts"
	},
	"fmt": {
		"useTabs": true,
		"semiColons": true,
		"lineWidth": 120
	},
	"imports": {
		"@july/snarl": "jsr:@july/snarl@^1.0.0",
		"@404/varnish": "jsr:@404/varnish@^0.1.1"
	},
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "@july/snarl",
		"lib": ["deno.ns", "dom", "dom.iterable"]
	},
	"lint": {
		"rules": {
			"tags": ["recommended"],
			"exclude": ["no-explicit-any"]
		}
	}
}
