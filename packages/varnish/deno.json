{
	"name": "@july/varnish",
	"description": "response post-processing middleware for snarl",
	"version": "0.1.0",
	"license": "Apache-2.0",
	"exports": {
		".": "./src/mod.ts"
	},
	"imports": {
		"@minify-html/deno": "jsr:@minify-html/deno@^0.18.1",
